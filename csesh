#!/usr/bin/env bash
set -euo pipefail

CLAUDE_DIR="${HOME}/.claude"
PROJECTS_DIR="${CLAUDE_DIR}/projects"

# Parse flags
show_all=false
json_output=false
for arg in "$@"; do
  case "$arg" in
    --all|-a) show_all=true ;;
    --json|-j) json_output=true ;;
  esac
done

# --- Collect running claude processes ---

declare -A PID_CWD
declare -A PID_TTY
declare -A PID_PPID

while read -r pid ppid tty _rest; do
  [ -z "$pid" ] && continue
  cwd=$(lsof -p "$pid" -Fn 2>/dev/null | grep '^n/' | head -1 | sed 's/^n//' || true)
  if [ -n "$cwd" ]; then
    PID_CWD[$pid]="$cwd"
    PID_TTY[$pid]="$tty"
    PID_PPID[$pid]="$ppid"
  fi
done < <(ps -eo pid,ppid,tty,args | grep '[/]claude' | grep -v 'deno' || true)

# --- Build JSON entries ---

if [ ! -d "$PROJECTS_DIR" ]; then
  if $json_output; then echo '[]'; else echo "No claude projects found."; fi
  exit 0
fi

# Track which paths we've seen (for orphan detection later)
declare -A seen_paths
json_entries=()

build_entry() {
  local name="$1" path="$2" running="$3" pid="$4" ppid="$5" tty="$6"
  local remote="$7" branch="$8" messages="$9" summary="${10}" url="${11}"
  jq -n \
    --arg name "$name" \
    --arg path "$path" \
    --argjson running "$running" \
    --arg pid "$pid" \
    --arg ppid "$ppid" \
    --arg tty "$tty" \
    --argjson remote "$remote" \
    --arg branch "$branch" \
    --argjson messages "$messages" \
    --arg summary "$summary" \
    --arg url "$url" \
    '{
      name: $name,
      path: $path,
      running: $running,
      pid: (if $pid == "" then null else ($pid | tonumber) end),
      ppid: (if $ppid == "" then null else ($ppid | tonumber) end),
      tty: (if $tty == "" then null else $tty end),
      remote_control: $remote,
      url: (if $url == "" then null else $url end),
      branch: (if $branch == "" then null else $branch end),
      messages: $messages,
      summary: (if $summary == "" then null else $summary end)
    }'
}

for project_dir in "${PROJECTS_DIR}"/*/; do
  [ -d "$project_dir" ] || continue
  basename_dir=$(basename "$project_dir")
  [[ "$basename_dir" == "memory" ]] && continue

  # Get project path: prefer sessions-index.json, fall back to matching running cwds
  index_file="${project_dir}sessions-index.json"
  original_path=""
  if [ -f "$index_file" ]; then
    original_path=$(jq -r '.originalPath // empty' "$index_file" 2>/dev/null || true)
  fi
  if [ -z "$original_path" ]; then
    for pid in "${!PID_CWD[@]}"; do
      encoded=$(echo "${PID_CWD[$pid]}" | sed 's|[/.]|-|g')
      if [[ "$basename_dir" == "$encoded" ]]; then
        original_path="${PID_CWD[$pid]}"
        break
      fi
    done
  fi
  [ -z "$original_path" ] && continue

  project_name=$(basename "$original_path")

  # Find matching running process
  running_pid=""
  for pid in "${!PID_CWD[@]}"; do
    cwd="${PID_CWD[$pid]}"
    if [[ "$cwd" == "$original_path" || "$cwd" == "$original_path"/* ]]; then
      running_pid="$pid"
      break
    fi
  done

  if [ -z "$running_pid" ] && ! $show_all; then
    continue
  fi

  seen_paths["$original_path"]=1

  # Remote control
  remote_control=false
  remote_url=""
  bridge_file="${project_dir}bridge-pointer.json"
  if [ -f "$bridge_file" ]; then
    remote_control=true
    session_id=$(jq -r '.sessionId // ""' "$bridge_file" 2>/dev/null || true)
    [ -n "$session_id" ] && remote_url="https://claude.ai/code/${session_id}"
  fi

  # Session info from sessions-index
  git_branch="" msg_count=0 session_summary=""
  if [ -f "$index_file" ]; then
    last_entry=$(jq '.entries | sort_by(.modified) | last' "$index_file" 2>/dev/null || true)
    if [ -n "$last_entry" ] && [ "$last_entry" != "null" ]; then
      git_branch=$(echo "$last_entry" | jq -r '.gitBranch // ""')
      msg_count=$(echo "$last_entry" | jq -r '.messageCount // 0')
      session_summary=$(echo "$last_entry" | jq -r '.summary // .firstPrompt // ""')
    fi
  fi
  msg_count=${msg_count:-0}
  [[ "$msg_count" =~ ^[0-9]+$ ]] || msg_count=0

  # Fallback: get branch from git
  if [ -z "$git_branch" ] && [ -d "$original_path/.git" ]; then
    git_branch=$(git -C "$original_path" branch --show-current 2>/dev/null || true)
  fi

  is_running=false running_ppid="" running_tty=""
  if [ -n "$running_pid" ]; then
    is_running=true
    running_ppid="${PID_PPID[$running_pid]:-}"
    running_tty="${PID_TTY[$running_pid]:-}"
  fi
  json_entries+=("$(build_entry \
    "$project_name" "$original_path" "$is_running" \
    "${running_pid:-}" "$running_ppid" "$running_tty" \
    "$remote_control" "$git_branch" "$msg_count" "$session_summary" "$remote_url")")
done

# Check for running processes with no matching project dir
for pid in "${!PID_CWD[@]}"; do
  cwd="${PID_CWD[$pid]}"
  already=false
  for seen in "${!seen_paths[@]}"; do
    if [[ "$cwd" == "$seen" || "$cwd" == "$seen"/* ]]; then
      already=true
      break
    fi
  done
  if ! $already; then
    json_entries+=("$(build_entry \
      "$(basename "$cwd")" "$cwd" true \
      "$pid" "${PID_PPID[$pid]:-}" "${PID_TTY[$pid]:-}" \
      false "" 0 "" "")")
  fi
done

# Assemble, sort, and output
if [ ${#json_entries[@]} -eq 0 ]; then
  if $json_output; then
    echo '[]'
  elif $show_all; then
    echo "No claude sessions found."
  else
    echo "No running claude sessions. Use --all to see all projects."
  fi
  exit 0
fi

json_sessions=$(printf '%s\n' "${json_entries[@]}" | jq -s 'sort_by((.running | not), .name)')

if $json_output; then
  echo "$json_sessions"
  exit 0
fi

# Human-readable table
echo "$json_sessions" | jq -r '.[] |
  [
    (if .running then "●" else "○" end),
    .name,
    (.branch // "-"),
    (.url // "-"),
    (if .pid then "PID \(.pid)" else "" end),
    (if .ppid then "PPID \(.ppid)" else "" end),
    (.tty // "")
  ] | join("\t")
' | column -ts $'\t'
